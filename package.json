{
  "name": "xyz",
  "version": "v4.23.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/geolytix/xyz"
  },
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "neverBuiltDependencies": []
  },
  "scripts": {
    "dev": "node --inspect express.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "_build": "node esbuild.config.mjs",
    "ui_css": "pnpm exec esbuild --bundle public/css/_ui.css --outfile=public/css/ui.css --external:*.woff2",
    "mapp_css": "pnpm exec esbuild --bundle public/css/_mapp.css --outfile=public/css/mapp.css",
    "generate-docs": "jsdoc --configure ./utils/jsdoc_mapp.json --verbose && jsdoc --configure ./utils/jsdoc_xyz.json --verbose && jsdoc --configure ./utils/jsdoc_test.json --verbose",
    "mapp-docs": "jsdoc --configure ./utils/jsdoc_mapp.json --verbose",
    "xyz-docs": "jsdoc --configure ./utils/jsdoc_xyz.json --verbose",
    "test-docs": "jsdoc --configure ./utils/jsdoc_test.json --verbose",
    "push-env": "node ./utils/sync-vercel-env.js"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/cloudfront-signer": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@node-saml/node-saml": "^5.1.0",
    "resend": "^6.12.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "~8.15.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@vitest/coverage-v8": "4.1.4",
    "clean-jsdoc-theme": "^4.3.2",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "esbuild": "^0.25.12",
    "express": "5.2.0",
    "express-rate-limit": "^7.5.1",
    "node-mocks-http": "^1.17.2",
    "nodemon": "^3.1.14",
    "undici": "^7.25.0",
    "vitest": "^4.1.4"
  }
}
