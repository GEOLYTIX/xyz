{
  "name": "xyz",
  "version": "v5.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/geolytix/xyz"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "neverBuiltDependencies": []
  },
  "scripts": {
    "dev": "node server.js --inspect",
    "test": "turbo run test",
    "test:xyz": "turbo run test --filter=xyz",
    "build": "turbo run build",
    "ui_css": "pnpm exec esbuild --bundle public/css/_ui.css --outfile=public/css/ui.css --external:*.woff2",
    "mapp_css": "pnpm exec esbuild --bundle public/css/_mapp.css --outfile=public/css/mapp.css",
    "generate-docs": "jsdoc --configure ./utils/jsdoc_mapp.json --verbose && jsdoc --configure ./utils/jsdoc_xyz.json --verbose",
    "mapp-docs": "jsdoc --configure ./utils/jsdoc_mapp.json --verbose",
    "xyz-docs": "jsdoc --configure ./utils/jsdoc_xyz.json --verbose",
    "push-env": "node ./utils/sync-vercel-env.js"
  },
  "license": "MIT",
  "dependencies": {
    "@geolytix/mapp": "file:apps/mapp",
    "@geolytix/xyz-app": "file:apps/xyz",
    "@geolytix/xyz-saml-app": "file:apps/saml"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@vitest/coverage-v8": "4.1.4",
    "clean-jsdoc-theme": "^4.3.0",
    "dotenv": "^17.4.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "node-mocks-http": "^1.17.2",
    "turbo": "^2.5.8",
    "undici": "^7.24.6",
    "vitest": "4.1.4"
  }
}
